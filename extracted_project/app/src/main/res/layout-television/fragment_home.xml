<?xml version="1.0" encoding="utf-8"?>
<!-- 📺 واجهة TV الملكية الأسطورية — LATCHI IPTV VIP (تصميم عصري فائق النظافة بدون تداخل) -->
<androidx.drawerlayout.widget.DrawerLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/drawerLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_tv_royal">

    <!-- Main Content Frame -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:paddingHorizontal="36dp"
            android:paddingTop="20dp"
            android:paddingBottom="24dp">

            <!-- ═══ الشريط العلوي الأنيق: ☰ + التاريخ + معلومات الاشتراك ═══ -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/menuButton"
                    android:layout_width="60dp"
                    android:layout_height="48dp"
                    android:background="@drawable/bg_gold_btn"
                    android:clickable="true"
                    android:focusable="true"
                    android:nextFocusDown="@id/cardLive"
                    android:gravity="center"
                    android:text="☰"
                    android:textColor="@color/gold_btn_text"
                    android:textSize="20sp"
                    android:textStyle="bold" />

                <!-- 📅 التاريخ -->
                <TextView
                    android:id="@+id/tvDateText"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="16dp"
                    android:layout_weight="1"
                    android:gravity="center_vertical"
                    android:text=""
                    android:textColor="#F5C542"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:shadowColor="#000000"
                    android:shadowDx="0"
                    android:shadowDy="1"
                    android:shadowRadius="4" />

                <!-- معلومات الاشتراك -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:gravity="end"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/loggedInText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text=""
                        android:textColor="#FFFFFF"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:shadowColor="#000000"
                        android:shadowDx="0"
                        android:shadowDy="1"
                        android:shadowRadius="3" />

                    <TextView
                        android:id="@+id/expiryText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text=""
                        android:textColor="#C7B7D8"
                        android:textSize="11sp"
                        android:shadowColor="#000000"
                        android:shadowDx="0"
                        android:shadowDy="1"
                        android:shadowRadius="3" />
                </LinearLayout>
            </LinearLayout>

            <!-- بروفايلات متعددة -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/usersRecyclerView"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:clipToPadding="false" />

            <!-- تنبيه التحديث -->
            <TextView
                android:id="@+id/updateBadge"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="6dp"
                android:background="@drawable/bg_gold_btn"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center"
                android:paddingHorizontal="20dp"
                android:text="🔄 تحديث جديد متاح"
                android:textColor="@color/gold_btn_text"
                android:textSize="14sp"
                android:textStyle="bold"
                android:visibility="gone" />

            <!-- بانر التنبيه -->
            <TextView
                android:id="@+id/expiryBanner"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="6dp"
                android:background="@drawable/bg_gold_btn"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center"
                android:paddingHorizontal="20dp"
                android:text=""
                android:textColor="@color/gold_btn_text"
                android:textSize="14sp"
                android:textStyle="bold"
                android:visibility="gone" />

            <!-- فراغ مرن يدفع الأزرار إلى الأسفل بنظافة -->
            <View
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1" />

            <!-- ═══ الصف الملكي الأول (الباقات الأساسية: مباشر، أفلام، مسلسلات) ═══ -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="76dp"
                android:layout_marginBottom="12dp"
                android:gravity="center"
                android:orientation="horizontal">

                <!-- 📡 المباشر -->
                <LinearLayout
                    android:id="@+id/cardLive"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:layout_marginEnd="12dp"
                    android:background="@drawable/bg_gold_btn"
                    android:clickable="true"
                    android:focusable="true"
                    android:nextFocusUp="@id/menuButton"
                    android:nextFocusDown="@id/cardMatches"
                    android:nextFocusRight="@id/cardMovies"
                    android:gravity="center"
                    android:orientation="horizontal"
                    android:paddingHorizontal="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="📺"
                        android:textSize="26sp"
                        android:layout_marginEnd="10dp" />

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="البث المباشر"
                            android:textColor="@color/gold_btn_text"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:duplicateParentState="true" />

                        <TextView
                            android:id="@+id/liveCount"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0 قناة"
                            android:textColor="@color/gold_btn_text"
                            android:textSize="11sp"
                            android:duplicateParentState="true" />
                    </LinearLayout>
                </LinearLayout>

                <!-- 🎬 الأفلام -->
                <LinearLayout
                    android:id="@+id/cardMovies"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:layout_marginEnd="12dp"
                    android:background="@drawable/bg_gold_btn"
                    android:clickable="true"
                    android:focusable="true"
                    android:nextFocusUp="@id/menuButton"
                    android:nextFocusDown="@id/toolbarSettings"
                    android:nextFocusLeft="@id/cardLive"
                    android:nextFocusRight="@id/cardSeries"
                    android:gravity="center"
                    android:orientation="horizontal"
                    android:paddingHorizontal="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🎬"
                        android:textSize="26sp"
                        android:layout_marginEnd="10dp" />

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="الأفلام"
                            android:textColor="@color/gold_btn_text"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:duplicateParentState="true" />

                        <TextView
                            android:id="@+id/movieCount"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0 فيلم"
                            android:textColor="@color/gold_btn_text"
                            android:textSize="11sp"
                            android:duplicateParentState="true" />
                    </LinearLayout>
                </LinearLayout>

                <!-- 📺 المسلسلات -->
                <LinearLayout
                    android:id="@+id/cardSeries"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:background="@drawable/bg_gold_btn"
                    android:clickable="true"
                    android:focusable="true"
                    android:nextFocusUp="@id/menuButton"
                    android:nextFocusDown="@id/toolbarUsers"
                    android:nextFocusLeft="@id/cardMovies"
                    android:gravity="center"
                    android:orientation="horizontal"
                    android:paddingHorizontal="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="📼"
                        android:textSize="26sp"
                        android:layout_marginEnd="10dp" />

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="المسلسلات"
                            android:textColor="@color/gold_btn_text"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:duplicateParentState="true" />

                        <TextView
                            android:id="@+id/seriesCount"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0 مسلسل"
                            android:textColor="@color/gold_btn_text"
                            android:textSize="11sp"
                            android:duplicateParentState="true" />
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>

            <!-- ═══ الصف الملكي الثاني (المباريات، الإعدادات، الحسابات، الذكاء الصوتي، واتساب) ═══ -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="64dp"
                android:gravity="center"
                android:orientation="horizontal">

                <!-- ⚽ المباريات -->
                <LinearLayout
                    android:id="@+id/cardMatches"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1.2"
                    android:layout_marginEnd="10dp"
                    android:background="@drawable/bg_gold_btn"
                    android:clickable="true"
                    android:focusable="true"
                    android:nextFocusUp="@id/cardLive"
                    android:nextFocusRight="@id/toolbarSettings"
                    android:gravity="center"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="⚽ المباريات"
                        android:textColor="@color/gold_btn_text"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:duplicateParentState="true" />
                </LinearLayout>

                <!-- ⚙️ الإعدادات -->
                <LinearLayout
                    android:id="@+id/toolbarSettings"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:layout_marginEnd="10dp"
                    android:background="@drawable/bg_gold_btn"
                    android:clickable="true"
                    android:focusable="true"
                    android:nextFocusUp="@id/cardMovies"
                    android:nextFocusLeft="@id/cardMatches"
                    android:nextFocusRight="@id/toolbarUsers"
                    android:gravity="center"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="⚙️ الإعدادات"
                        android:textColor="@color/gold_btn_text"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:duplicateParentState="true" />
                </LinearLayout>

                <!-- 👤 المستخدم -->
                <LinearLayout
                    android:id="@+id/toolbarUsers"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1.2"
                    android:layout_marginEnd="10dp"
                    android:background="@drawable/bg_gold_btn"
                    android:clickable="true"
                    android:focusable="true"
                    android:nextFocusUp="@id/cardSeries"
                    android:nextFocusLeft="@id/toolbarSettings"
                    android:nextFocusRight="@id/whatsappButton"
                    android:gravity="center"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="👤 الحسابات"
                        android:textColor="@color/gold_btn_text"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:duplicateParentState="true" />
                </LinearLayout>

                <!-- 📞 واتساب -->
                <LinearLayout
                    android:id="@+id/whatsappButton"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:background="@drawable/bg_gold_btn"
                    android:clickable="true"
                    android:focusable="true"
                    android:nextFocusUp="@id/cardSeries"
                    android:nextFocusLeft="@id/toolbarUsers"
                    android:gravity="center"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="📞 الدعم"
                        android:textColor="@color/gold_btn_text"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:duplicateParentState="true" />
                </LinearLayout>
            </LinearLayout>

            <!-- ═══ العناصر المخفية المطلوبة لعمل الكود ═══ -->
            <TextView android:id="@+id/lastWatchedButton" android:layout_width="wrap_content" android:layout_height="wrap_content" android:visibility="gone" />
            <LinearLayout android:id="@+id/backToHomeButton" android:layout_width="wrap_content" android:layout_height="wrap_content" android:visibility="gone" />
            <TextView android:id="@+id/updatedText" android:layout_width="wrap_content" android:layout_height="wrap_content" android:visibility="gone" />
            <LinearLayout android:id="@+id/loadingRow" android:layout_width="wrap_content" android:layout_height="wrap_content" android:visibility="gone">
                <ProgressBar android:layout_width="20dp" android:layout_height="20dp" />
            </LinearLayout>
        </LinearLayout>

        <!-- 🎙️ واجهة AI Voice السفلية -->
        <include
            android:id="@+id/voiceOverlay"
            layout="@layout/voice_overlay"
            android:visibility="gone" />

        <!-- Loading Overlay -->
        <FrameLayout
            android:id="@+id/loadingOverlay"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="#AA000000"
            android:clickable="true"
            android:focusable="false"
            android:visibility="gone">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:gravity="center"
                android:orientation="vertical"
                android:padding="24dp">

                <ProgressBar
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:layout_marginBottom="16dp" />

                <TextView
                    android:id="@+id/loadingTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="8dp"
                    android:text="@string/loading_adhkar_title"
                    android:textColor="#FFD700"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/loadingText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:lineSpacingExtra="6dp"
                    android:text="سبحان الله وبحمده"
                    android:textColor="#FFFFFF"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/loadingRef"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:gravity="center"
                    android:text=""
                    android:textColor="#C7B7D8"
                    android:textSize="12sp" />
            </LinearLayout>
        </FrameLayout>
    </FrameLayout>

    <!-- Navigation Drawer -->
    <LinearLayout
        android:id="@+id/drawerMenu"
        android:layout_width="300dp"
        android:layout_height="match_parent"
        android:layout_gravity="end"
        android:background="#121228"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:gravity="center"
            android:text="LATCHI IPTV VIP"
            android:textColor="#FFD700"
            android:textSize="22sp"
            android:textStyle="bold" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginVertical="14dp"
            android:background="#2d2d44" />

        <TextView
            android:id="@+id/drawerMatches"
            android:layout_width="match_parent"
            android:layout_height="46dp"
            android:layout_marginBottom="8dp"
            android:background="@drawable/bg_gold_btn"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center_vertical"
            android:paddingHorizontal="16dp"
            android:text="@string/drawer_matches"
            android:textColor="@color/gold_btn_text"
            android:textSize="15sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/drawerPrayer"
            android:layout_width="match_parent"
            android:layout_height="46dp"
            android:layout_marginBottom="8dp"
            android:background="@drawable/bg_gold_btn"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center_vertical"
            android:paddingHorizontal="16dp"
            android:text="@string/drawer_prayer"
            android:textColor="@color/gold_btn_text"
            android:textSize="15sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/drawerPricing"
            android:layout_width="match_parent"
            android:layout_height="46dp"
            android:layout_marginBottom="8dp"
            android:background="@drawable/bg_gold_btn"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center_vertical"
            android:paddingHorizontal="16dp"
            android:text="@string/drawer_pricing"
            android:textColor="@color/gold_btn_text"
            android:textSize="15sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/drawerThemeSettings"
            android:layout_width="match_parent"
            android:layout_height="46dp"
            android:layout_marginBottom="8dp"
            android:background="@drawable/bg_gold_btn"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center_vertical"
            android:paddingHorizontal="16dp"
            android:text="@string/theme_settings"
            android:textColor="@color/gold_btn_text"
            android:textSize="15sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/drawerSettings"
            android:layout_width="match_parent"
            android:layout_height="46dp"
            android:layout_marginBottom="8dp"
            android:background="@drawable/bg_gold_btn"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center_vertical"
            android:paddingHorizontal="16dp"
            android:text="@string/drawer_settings"
            android:textColor="@color/gold_btn_text"
            android:textSize="15sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/drawerAbout"
            android:layout_width="match_parent"
            android:layout_height="46dp"
            android:layout_marginBottom="8dp"
            android:background="@drawable/bg_gold_btn"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center_vertical"
            android:paddingHorizontal="16dp"
            android:text="@string/drawer_about"
            android:textColor="@color/gold_btn_text"
            android:textSize="15sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/drawerShare"
            android:layout_width="match_parent"
            android:layout_height="46dp"
            android:layout_marginBottom="8dp"
            android:background="@drawable/bg_gold_btn"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center_vertical"
            android:paddingHorizontal="16dp"
            android:text="📤 مشاركة التطبيق"
            android:textColor="@color/gold_btn_text"
            android:textSize="15sp"
            android:textStyle="bold" />

        <View
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:gravity="center"
            android:text="@string/developed_by"
            android:textColor="#666666"
            android:textSize="11sp" />
    </LinearLayout>
</androidx.drawerlayout.widget.DrawerLayout>
