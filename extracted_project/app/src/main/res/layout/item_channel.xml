<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="@dimen/item_height"
    android:layout_marginBottom="@dimen/item_margin_bottom"
    android:background="@drawable/bg_panel_focusable"
    android:clickable="true"
    android:focusable="true"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:paddingStart="12dp"
    android:paddingEnd="12dp">

    <ImageView
        android:id="@+id/logoImageView"
        android:layout_width="@dimen/item_logo"
        android:layout_height="@dimen/item_logo"
        android:background="#22163A"
        android:contentDescription="Channel Logo"
        android:padding="@dimen/item_logo_padding"
        android:scaleType="fitCenter"
        android:src="@drawable/ic_tv" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_marginStart="12dp"
        android:layout_weight="1"
        android:gravity="center_vertical"
        android:orientation="vertical">

        <TextView
            android:id="@+id/nameTextView"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:ellipsize="end"
            android:maxLines="1"
            android:text="Channel Name"
            android:textColor="@android:color/white"
            android:textSize="@dimen/item_name"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/categoryTextView"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/item_cat_margin_top"
            android:ellipsize="end"
            android:maxLines="1"
            android:text="Category"
            android:textColor="#C7B7D8"
            android:textSize="@dimen/item_category" />

        <TextView
            android:id="@+id/epgTextView"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:ellipsize="marquee"
            android:marqueeRepeatLimit="marquee_forever"
            android:singleLine="true"
            android:textColor="#4ADE80"
            android:textSize="10sp"
            android:visibility="gone" />
    </LinearLayout>

    <ImageView
        android:id="@+id/favoriteButton"
        android:layout_width="@dimen/item_fav_size"
        android:layout_height="@dimen/item_fav_size"
        android:clickable="true"
        android:contentDescription="Favorite"
        android:focusable="false"
        android:foreground="@drawable/focus_selector"
        android:nextFocusRight="@id/typeBadgeTextView"
        android:padding="@dimen/item_fav_padding"
        android:scaleType="fitCenter"
        android:src="@drawable/ic_heart_outline" />

    <TextView
        android:id="@+id/typeBadgeTextView"
        android:layout_width="@dimen/item_badge_width"
        android:layout_height="@dimen/item_badge_height"
        android:gravity="center"
        android:nextFocusLeft="@id/favoriteButton"
        android:text="LIVE"
        android:textColor="@android:color/white"
        android:textSize="@dimen/item_badge_text"
        android:textStyle="bold" />
</LinearLayout>
