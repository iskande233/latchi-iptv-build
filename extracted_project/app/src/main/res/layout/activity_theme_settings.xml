<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_app"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:id="@+id/backButton"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:clickable="true"
            android:focusable="true"
            android:foreground="@drawable/focus_selector"
            android:gravity="center_vertical"
            android:text="@string/back"
            android:textColor="@android:color/white"
            android:textSize="20sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:gravity="center"
            android:text="@string/available_themes"
            android:textColor="#FFD700"
            android:textSize="18sp"
            android:textStyle="bold" />

        <!-- Default Theme -->
        <LinearLayout
            android:id="@+id/themeDefault"
            android:layout_width="match_parent"
            android:layout_height="80dp"
            android:layout_marginTop="16dp"
            android:background="@drawable/bg_panel_premium"
            android:clickable="true"
            android:focusable="true"
            android:foreground="@drawable/focus_selector"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:padding="16dp">

            <TextView
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:background="@drawable/bg_app"
                android:gravity="center"
                android:text="🌑"
                android:textSize="24sp" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_weight="1"
                android:text="@string/theme_default"
                android:textColor="@android:color/white"
                android:textSize="16sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- Dark Theme -->
        <LinearLayout
            android:id="@+id/themeDark"
            android:layout_width="match_parent"
            android:layout_height="80dp"
            android:layout_marginTop="12dp"
            android:background="@drawable/bg_panel_premium"
            android:clickable="true"
            android:focusable="true"
            android:foreground="@drawable/focus_selector"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:padding="16dp">

            <TextView
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:background="#1a1a2e"
                android:gravity="center"
                android:text="🌌"
                android:textSize="24sp" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_weight="1"
                android:text="@string/theme_dark"
                android:textColor="@android:color/white"
                android:textSize="16sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- Space Theme -->
        <LinearLayout
            android:id="@+id/themeSpace"
            android:layout_width="match_parent"
            android:layout_height="80dp"
            android:layout_marginTop="12dp"
            android:background="@drawable/bg_panel_premium"
            android:clickable="true"
            android:focusable="true"
            android:foreground="@drawable/focus_selector"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:padding="16dp">

            <TextView
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:background="#0d1b2a"
                android:gravity="center"
                android:text="🚀"
                android:textSize="24sp" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_weight="1"
                android:text="Space"
                android:textColor="@android:color/white"
                android:textSize="16sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- Nature Theme -->
        <LinearLayout
            android:id="@+id/themeNature"
            android:layout_width="match_parent"
            android:layout_height="80dp"
            android:layout_marginTop="12dp"
            android:background="@drawable/bg_panel_premium"
            android:clickable="true"
            android:focusable="true"
            android:foreground="@drawable/focus_selector"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:padding="16dp">

            <TextView
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:background="#1b4332"
                android:gravity="center"
                android:text="🌿"
                android:textSize="24sp" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_weight="1"
                android:text="Nature"
                android:textColor="@android:color/white"
                android:textSize="16sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- Custom Image -->
        <LinearLayout
            android:id="@+id/themeCustom"
            android:layout_width="match_parent"
            android:layout_height="80dp"
            android:layout_marginTop="12dp"
            android:background="@drawable/bg_panel_premium"
            android:clickable="true"
            android:focusable="true"
            android:foreground="@drawable/focus_selector"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:padding="16dp">

            <TextView
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:background="@drawable/bg_button_primary"
                android:gravity="center"
                android:text="📷"
                android:textSize="24sp" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_weight="1"
                android:text="@string/choose_gallery"
                android:textColor="@android:color/white"
                android:textSize="16sp"
                android:textStyle="bold" />
        </LinearLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:gravity="center"
            android:text="@string/developed_by"
            android:textColor="#C7B7D8"
            android:textSize="14sp" />
    </LinearLayout>
</ScrollView>
