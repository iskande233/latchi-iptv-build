<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_focused="true">
        <layer-list>
            <item>
                <shape android:shape="rectangle">
                    <stroke android:width="2dp" android:color="#80FFD700" />
                    <corners android:radius="14dp" />
                    <solid android:color="@android:color/transparent" />
                </shape>
            </item>
            <item android:left="-3dp" android:right="-3dp" android:top="-3dp" android:bottom="-3dp">
                <shape android:shape="rectangle">
                    <stroke android:width="1dp" android:color="#33FFD700" />
                    <corners android:radius="14dp" />
                    <solid android:color="@android:color/transparent" />
                </shape>
            </item>
        </layer-list>
    </item>
    <item android:state_pressed="true">
        <layer-list>
            <item>
                <shape android:shape="rectangle">
                    <stroke android:width="2dp" android:color="#807FE6FF" />
                    <corners android:radius="14dp" />
                    <solid android:color="@android:color/transparent" />
                </shape>
            </item>
        </layer-list>
    </item>
    <item>
        <shape android:shape="rectangle">
            <stroke android:width="0dp" android:color="@android:color/transparent" />
            <corners android:radius="14dp" />
            <solid android:color="@android:color/transparent" />
        </shape>
    </item>
</selector>
