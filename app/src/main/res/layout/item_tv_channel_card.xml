<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/chCardRoot"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_panel_premium_focusable"
    android:clickable="true"
    android:focusable="true"
    android:foreground="@drawable/focus_selector"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:paddingHorizontal="12dp"
    android:paddingVertical="10dp"
    android:layout_marginBottom="8dp">

    <ImageView
        android:id="@+id/chLogoImg"
        android:layout_width="44dp"
        android:layout_height="44dp"
        android:scaleType="centerCrop"
        android:layout_marginEnd="12dp"
        android:background="#121228" />

    <TextView
        android:id="@+id/chNameText"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:ellipsize="marquee"
        android:marqueeRepeatLimit="marquee_forever"
        android:singleLine="true"
        android:text="Channel Name"
        android:textColor="#FFFFFF"
        android:textSize="15sp"
        android:textStyle="bold" />

    <ImageView
        android:id="@+id/chFavImg"
        android:layout_width="24dp"
        android:layout_height="24dp"
        android:src="@drawable/ic_heart_filled"
        android:tint="#FFD700"
        android:visibility="gone" />
</LinearLayout>
