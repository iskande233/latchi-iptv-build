<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#050A1A">

    <!-- Toolbar -->
    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        android:layout_width="0dp"
        android:layout_height="?attr/actionBarSize"
        android:background="#121228"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:padding="8dp">

            <TextView
                android:id="@+id/toolbar_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerVertical="true"
                android:text="📡 مقياس سرعة الإنترنت • Fast Speed Test"
                android:textColor="#FFD700"
                android:textSize="18sp"
                android:textStyle="bold" />

        </RelativeLayout>
    </androidx.appcompat.widget.Toolbar>

    <!-- Latency and Speed Section -->
    <LinearLayout
        android:id="@+id/statusLayout"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="20dp"
        app:layout_constraintTop_toBottomOf="@id/toolbar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Latency Card -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:layout_margin="10dp"
            android:orientation="vertical"
            android:background="@drawable/bg_button_primary"
            android:padding="16dp">

            <TextView
                android:id="@+id/latencyTxt"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0 ms"
                android:textColor="#39FF8B"
                android:textSize="20sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="5dp"
                android:textColor="#A5B4FC"
                android:text="سرعة الاستجابة / Latency"
                android:textSize="13sp" />

        </LinearLayout>

        <!-- Speed Card -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:layout_margin="10dp"
            android:orientation="vertical"
            android:background="@drawable/bg_button_primary"
            android:padding="16dp">

            <TextView
                android:id="@+id/speedTxt"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0.0 Mbps"
                android:textColor="#FFD700"
                android:textSize="20sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="5dp"
                android:textColor="#A5B4FC"
                android:text="سرعة التحميل / Download"
                android:textSize="13sp" />

        </LinearLayout>

    </LinearLayout>

    <!-- Speed Gauge and Button Section -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintTop_toBottomOf="@id/statusLayout"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:padding="24dp">

        <!-- Outer gauge track -->
        <ProgressBar
            android:id="@+id/speedGauge"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="320dp"
            android:layout_height="18dp"
            android:layout_centerHorizontal="true"
            android:layout_marginTop="20dp"
            android:max="150"
            android:progress="0"
            android:progressDrawable="@drawable/splash_progress_blue" />

        <!-- Circular Big Start Test Button (glowing and focusable) -->
        <TextView
            android:id="@+id/startTestBT"
            android:layout_width="220dp"
            android:layout_height="54dp"
            android:layout_below="@id/speedGauge"
            android:layout_centerHorizontal="true"
            android:layout_marginTop="40dp"
            android:background="@drawable/bg_gold_btn"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:text="🔌 ابدأ الفحص / Start Test"
            android:textColor="#050A1A"
            android:textSize="16sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_below="@id/startTestBT"
            android:layout_centerHorizontal="true"
            android:layout_marginTop="16dp"
            android:textColor="#7A82A8"
            android:textSize="11sp"
            android:text="نظام القياس والربط مباشر ومحمي بمحرك Fast.com ✓" />

    </RelativeLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
