<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/drawerLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_app">

    <!-- Main Content -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:fillViewport="true">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="@dimen/padding_default">

                <!-- Header Row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/header_height"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <ImageView
                        android:id="@+id/headerLogo"
                        android:layout_width="@dimen/header_logo"
                        android:layout_height="@dimen/header_logo"
                        android:scaleType="fitCenter"
                        android:src="@drawable/ic_tv" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:layout_weight="1"
                        android:text="LATCHI IPTV"
                        android:textColor="@android:color/white"
                        android:textSize="@dimen/header_text"
                        android:textStyle="bold" />

                    <!-- Hamburger Menu -->
                    <TextView
                        android:id="@+id/menuButton"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:layout_marginEnd="8dp"
                        android:background="@drawable/bg_panel_premium"
                        android:clickable="true"
                        android:focusable="true"
                        android:foreground="@drawable/focus_selector"
                        android:gravity="center"
                        android:text="☰"
                        android:textColor="@android:color/white"
                        android:textSize="20sp"
                        android:textStyle="bold" />

                    <!-- ✨ Professional Gemini AI Button -->
                    <ImageView
                        android:id="@+id/cardAIVoice"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:background="@drawable/bg_panel_premium"
                        android:clickable="true"
                        android:focusable="true"
                        android:foreground="@drawable/focus_selector"
                        android:padding="8dp"
                        android:src="@drawable/ic_gemini_professional"
                        android:contentDescription="Gemini AI" />
                </LinearLayout>

                <!-- User Profiles Row -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="@string/users"
                    android:textColor="#C7B7D8"
                    android:textSize="12sp"
                    android:textStyle="bold" />

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/usersRecyclerView"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:clipToPadding="false" />

                <TextView
                    android:id="@+id/updateBadge"
                    android:layout_width="match_parent"
                    android:layout_height="34dp"
                    android:layout_marginTop="10dp"
                    android:background="@drawable/bg_button_primary"
                    android:clickable="true"
                    android:focusable="true"
                    android:focusableInTouchMode="true"
                    android:foreground="@drawable/focus_selector"
                    android:gravity="center"
                    android:text="🔄 تحديث جديد متاح"
                    android:textColor="@android:color/white"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:visibility="gone" />

                <!-- ⏰ بانر تنبيه قرب انتهاء الاشتراك -->
                <TextView
                    android:id="@+id/expiryBanner"
                    android:layout_width="match_parent"
                    android:layout_height="34dp"
                    android:layout_marginTop="8dp"
                    android:background="@drawable/bg_gold_btn"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center"
                    android:text=""
                    android:textColor="#000000"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:visibility="gone" />

                <!-- Info Bars -->
                <TextView
                    android:id="@+id/loggedInText"
                    android:layout_width="match_parent"
                    android:layout_height="40dp"
                    android:layout_marginTop="10dp"
                    android:background="@drawable/bg_panel"
                    android:ellipsize="end"
                    android:gravity="center"
                    android:maxLines="1"
                    android:text="Logged In"
                    android:textColor="@android:color/white"
                    android:textSize="14sp" />

                <TextView
                    android:id="@+id/expiryText"
                    android:layout_width="match_parent"
                    android:layout_height="40dp"
                    android:layout_marginTop="10dp"
                    android:background="@drawable/bg_panel"
                    android:ellipsize="end"
                    android:gravity="center"
                    android:maxLines="1"
                    android:text="Expiry"
                    android:textColor="@android:color/white"
                    android:textSize="14sp" />

                <TextView
                    android:id="@+id/lastWatchedButton"
                    android:visibility="gone"
                    android:layout_width="match_parent"
                    android:layout_height="44dp"
                    android:layout_marginTop="10dp"
                    android:background="@drawable/bg_panel_premium"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="@drawable/focus_selector"
                    android:gravity="center"
                    android:text="@string/continue_watching"
                    android:textColor="@android:color/white"
                    android:textSize="15sp" />

                <TextView
                    android:id="@+id/updatedText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:gravity="center"
                    android:text="@string/last_update"
                    android:textColor="#FFD700"
                    android:textSize="13sp"
                    android:textStyle="bold" />

                <!-- 🕌 بطاقة الأذكار اليومية المضيئة للهاتف -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:background="@drawable/bg_panel_premium"
                    android:paddingHorizontal="16dp"
                    android:paddingVertical="10dp"
                    android:gravity="center">

                    <TextView
                        android:id="@+id/adhkarBannerText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="سبحان الله وبحمده، سبحان الله العظيم"
                        android:textColor="#FFD700"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:gravity="center" />
                </LinearLayout>

                <!-- Quick Actions Row -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="40dp" android:layout_marginTop="12dp" android:gravity="center" android:orientation="horizontal">
                    <LinearLayout android:id="@+id/toolbarSettingsTop" android:layout_width="0dp" android:layout_height="match_parent" android:layout_marginEnd="6dp" android:layout_weight="1" android:background="@drawable/bg_settings_btn" android:clickable="true" android:focusable="true" android:foreground="@drawable/focus_selector" android:gravity="center"><TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/settings_btn" android:textColor="@android:color/white" android:textSize="12sp" android:textStyle="bold" /></LinearLayout>
                    <LinearLayout android:id="@+id/toolbarUsersTop" android:layout_width="0dp" android:layout_height="match_parent" android:layout_marginStart="6dp" android:layout_weight="1" android:background="@drawable/bg_update_btn" android:clickable="true" android:focusable="true" android:foreground="@drawable/focus_selector" android:gravity="center"><TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/favorites" android:textColor="@android:color/white" android:textSize="12sp" android:textStyle="bold" /></LinearLayout>
                </LinearLayout>

                <!-- 📱 Professional Phone Cards with TV-style icons (smaller version) 📱 -->
                <!-- Live Card -->
                <FrameLayout
                    android:id="@+id/cardLive"
                    android:layout_width="match_parent"
                    android:layout_height="76dp"
                    android:layout_marginTop="10dp"
                    android:background="@drawable/bg_panel_premium_focusable"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="@drawable/focus_selector"
                    android:elevation="6dp">

                    <ImageView
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:scaleType="centerCrop"
                        android:adjustViewBounds="false"
                        android:src="@drawable/phone_card_live"
                        android:contentDescription="@string/live_tv" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_gravity="bottom|start"
                        android:visibility="gone"
                        android:background="#88000000"
                        android:orientation="vertical"
                        android:paddingHorizontal="12dp"
                        android:paddingVertical="4dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/live_tv"
                            android:textColor="@android:color/white"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:shadowColor="#000000"
                            android:shadowDx="2"
                            android:shadowDy="2"
                            android:shadowRadius="4" />

                        <TextView
                            android:id="@+id/liveCount"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="1dp"
                            android:text="متاح الآن ✓"
                            android:textColor="#39FF8B"
                            android:textSize="10sp"
                            android:shadowColor="#000000"
                            android:shadowDx="2"
                            android:shadowDy="2"
                            android:shadowRadius="4" />
                    </LinearLayout>
                </FrameLayout>

                <!-- 🏆 beIN Sports Card (مخصص لقنوات beIN فقط) -->
                <FrameLayout
                    android:id="@+id/cardBeInSports"
                    android:layout_width="match_parent"
                    android:layout_height="84dp"
                    android:layout_marginTop="10dp"
                    android:background="@drawable/bg_panel_premium_focusable"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="@drawable/focus_selector"
                    android:elevation="8dp">

                    <ImageView
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:scaleType="centerCrop"
                        android:adjustViewBounds="false"
                        android:src="@drawable/phone_card_bein"
                        android:contentDescription="beIN Sports" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_gravity="bottom|start"
                        android:visibility="gone"
                        android:background="#99000000"
                        android:orientation="vertical"
                        android:paddingHorizontal="12dp"
                        android:paddingVertical="4dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="🏆 beIN Sports"
                            android:textColor="@android:color/white"
                            android:textSize="17sp"
                            android:textStyle="bold"
                            android:shadowColor="#9D4EDD"
                            android:shadowDx="2"
                            android:shadowDy="2"
                            android:shadowRadius="6" />

                        <TextView
                            android:id="@+id/beinSportsCount"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="1dp"
                            android:text="قنوات beIN + MAX + كأس العالم"
                            android:textColor="#C77DFF"
                            android:textSize="10sp"
                            android:shadowColor="#000000"
                            android:shadowDx="1"
                            android:shadowDy="1"
                            android:shadowRadius="3" />
                    </LinearLayout>
                </FrameLayout>

                <!-- Movies Card -->
                <FrameLayout
                    android:id="@+id/cardMovies"
                    android:layout_width="match_parent"
                    android:layout_height="76dp"
                    android:layout_marginTop="8dp"
                    android:background="@drawable/bg_panel_premium_focusable"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="@drawable/focus_selector"
                    android:elevation="6dp">

                    <ImageView
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:scaleType="centerCrop"
                        android:adjustViewBounds="false"
                        android:src="@drawable/phone_card_films"
                        android:contentDescription="@string/movies" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_gravity="bottom|start"
                        android:visibility="gone"
                        android:background="#88000000"
                        android:orientation="vertical"
                        android:paddingHorizontal="12dp"
                        android:paddingVertical="4dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/movies"
                            android:textColor="@android:color/white"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:shadowColor="#000000"
                            android:shadowDx="2"
                            android:shadowDy="2"
                            android:shadowRadius="4" />

                        <TextView
                            android:id="@+id/movieCount"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="1dp"
                            android:text="متاح الآن ✓"
                            android:textColor="#7FE6FF"
                            android:textSize="10sp"
                            android:shadowColor="#000000"
                            android:shadowDx="2"
                            android:shadowDy="2"
                            android:shadowRadius="4" />
                    </LinearLayout>
                </FrameLayout>

                <!-- Series Card -->
                <FrameLayout
                    android:id="@+id/cardSeries"
                    android:layout_width="match_parent"
                    android:layout_height="76dp"
                    android:layout_marginTop="8dp"
                    android:background="@drawable/bg_panel_premium_focusable"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="@drawable/focus_selector"
                    android:elevation="6dp">

                    <ImageView
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:scaleType="centerCrop"
                        android:adjustViewBounds="false"
                        android:src="@drawable/phone_card_series"
                        android:contentDescription="@string/series" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_gravity="bottom|start"
                        android:visibility="gone"
                        android:background="#88000000"
                        android:orientation="vertical"
                        android:paddingHorizontal="12dp"
                        android:paddingVertical="4dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/series"
                            android:textColor="@android:color/white"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:shadowColor="#000000"
                            android:shadowDx="2"
                            android:shadowDy="2"
                            android:shadowRadius="4" />

                        <TextView
                            android:id="@+id/seriesCount"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="1dp"
                            android:text="متاح الآن ✓"
                            android:textColor="#FFB347"
                            android:textSize="10sp"
                            android:shadowColor="#000000"
                            android:shadowDx="2"
                            android:shadowDy="2"
                            android:shadowRadius="4" />
                    </LinearLayout>
                </FrameLayout>

                <!-- Matches Card -->
                <FrameLayout
                    android:id="@+id/cardMatches"
                    android:layout_width="match_parent"
                    android:layout_height="76dp"
                    android:layout_marginTop="8dp"
                    android:background="@drawable/bg_panel_premium_focusable"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="@drawable/focus_selector"
                    android:elevation="6dp">

                    <ImageView
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:scaleType="centerCrop"
                        android:adjustViewBounds="false"
                        android:src="@drawable/phone_card_matches"
                        android:contentDescription="@string/matches_title" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_gravity="bottom|start"
                        android:visibility="gone"
                        android:background="#88000000"
                        android:orientation="vertical"
                        android:paddingHorizontal="12dp"
                        android:paddingVertical="4dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/matches_title"
                            android:textColor="@android:color/white"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:shadowColor="#000000"
                            android:shadowDx="2"
                            android:shadowDy="2"
                            android:shadowRadius="4" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="1dp"
                            android:text="@string/todays_matches"
                            android:textColor="#A5B4FC"
                            android:textSize="10sp"
                            android:shadowColor="#000000"
                            android:shadowDx="2"
                            android:shadowDy="2"
                            android:shadowRadius="4" />
                    </LinearLayout>
                </FrameLayout>

                <!-- Loading Row -->
                <LinearLayout
                    android:id="@+id/loadingRow"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:layout_marginTop="20dp"
                    android:gravity="center"
                    android:orientation="horizontal"
                    android:visibility="gone">

                    <ProgressBar
                        android:id="@+id/progressBar"
                        android:layout_width="36dp"
                        android:layout_height="36dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="10dp"
                        android:text="@string/loading_dots"
                        android:textColor="@android:color/white"
                        android:textSize="14sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <!-- Whatsapp Footer -->
                <LinearLayout
                    android:id="@+id/whatsappButton"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:layout_marginTop="24dp"
                    android:background="@drawable/bg_whatsapp"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="@drawable/focus_selector"
                    android:gravity="center"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="10dp"
                        android:text="✆"
                        android:textColor="@android:color/white"
                        android:textSize="20sp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/whatsapp_contact"
                        android:textColor="@android:color/white"
                        android:textSize="14sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:gravity="center"
                    android:text="@string/developed_by"
                    android:textColor="#7A82A8"
                    android:textSize="11sp" />
            </LinearLayout>
        </ScrollView>

        <!-- 🎙️ AI Voice Overlay -->
        <include
            layout="@layout/voice_overlay"
            android:visibility="gone" />

        <FrameLayout
            android:id="@+id/loadingOverlay"
            android:layout_width="1dp"
            android:layout_height="1dp"
            android:visibility="gone" />
    </FrameLayout>

    <!-- Navigation Drawer -->
    <LinearLayout
        android:id="@+id/drawerMenu"
        android:layout_width="280dp"
        android:layout_height="match_parent"
        android:layout_gravity="end"
        android:background="#121228"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:gravity="center"
            android:text="LATCHI IPTV"
            android:textColor="#FFD700"
            android:textSize="22sp"
            android:textStyle="bold" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginVertical="16dp"
            android:background="#2d2d44" />
        <TextView
            android:id="@+id/drawerSupport"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginBottom="8dp"
            android:background="@drawable/bg_vip_grid_card"
            android:clickable="true"
            android:focusable="true"
            android:foreground="@drawable/focus_selector"
            android:gravity="center_vertical"
            android:paddingHorizontal="16dp"
            android:text="📞 الدعم الفني"
            android:textColor="@android:color/white"
            android:textSize="16sp"
            android:textStyle="bold" />


        <TextView
            android:id="@+id/drawerMatches"
            android:nextFocusUp="@id/drawerMatches"
            android:nextFocusDown="@id/drawerPrayer"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginBottom="8dp"
            android:background="@drawable/bg_panel_premium_focusable"
            android:clickable="true"
            android:focusable="true"
            android:foreground="@drawable/focus_selector"
            android:gravity="center_vertical"
            android:paddingHorizontal="16dp"
            android:text="@string/drawer_matches"
            android:textColor="@android:color/white"
            android:textSize="16sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/drawerPrayer"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginBottom="8dp"
            android:background="@drawable/bg_panel_premium_focusable"
            android:clickable="true"
            android:focusable="true"
            android:foreground="@drawable/focus_selector"
            android:gravity="center_vertical"
            android:paddingHorizontal="16dp"
            android:text="@string/drawer_prayer"
            android:textColor="@android:color/white"
            android:textSize="16sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/drawerPricing"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginBottom="8dp"
            android:background="@drawable/bg_panel_premium_focusable"
            android:clickable="true"
            android:focusable="true"
            android:foreground="@drawable/focus_selector"
            android:gravity="center_vertical"
            android:paddingHorizontal="16dp"
            android:text="@string/drawer_pricing"
            android:textColor="@android:color/white"
            android:textSize="16sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/drawerThemeSettings"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginBottom="8dp"
            android:background="@drawable/bg_panel_premium_focusable"
            android:clickable="true"
            android:focusable="true"
            android:foreground="@drawable/focus_selector"
            android:gravity="center_vertical"
            android:paddingHorizontal="16dp"
            android:text="@string/theme_settings"
            android:textColor="@android:color/white"
            android:textSize="16sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/drawerSettings"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginBottom="8dp"
            android:background="@drawable/bg_panel_premium_focusable"
            android:clickable="true"
            android:focusable="true"
            android:foreground="@drawable/focus_selector"
            android:gravity="center_vertical"
            android:paddingHorizontal="16dp"
            android:text="@string/drawer_settings"
            android:textColor="@android:color/white"
            android:textSize="16sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/drawerAbout"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginBottom="8dp"
            android:background="@drawable/bg_panel_premium_focusable"
            android:clickable="true"
            android:focusable="true"
            android:foreground="@drawable/focus_selector"
            android:gravity="center_vertical"
            android:paddingHorizontal="16dp"
            android:text="@string/drawer_about"
            android:textColor="@android:color/white"
            android:textSize="16sp"
            android:textStyle="bold" />

        <View
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:gravity="center"
            android:text="@string/developed_by"
            android:textColor="#666666"
            android:textSize="11sp" />
    </LinearLayout>
</androidx.drawerlayout.widget.DrawerLayout>
