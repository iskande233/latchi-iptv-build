<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/drawerLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_app">

    <!-- Main Content -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:fillViewport="true">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="@dimen/padding_default">

                <!-- Header Row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/header_height"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <ImageView
                        android:id="@+id/headerLogo"
                        android:layout_width="@dimen/header_logo"
                        android:layout_height="@dimen/header_logo"
                        android:scaleType="fitCenter"
                        android:src="@drawable/ic_tv" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:layout_weight="1"
                        android:text="LATCHI IPTV"
                        android:textColor="@android:color/white"
                        android:textSize="@dimen/header_text"
                        android:textStyle="bold" />

                    <!-- Hamburger Menu -->
                    <TextView
                        android:id="@+id/menuButton"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:layout_marginEnd="8dp"
                        android:background="@drawable/bg_panel_premium"
                        android:clickable="true"
                        android:focusable="true"
                        android:foreground="@drawable/focus_selector"
                        android:gravity="center"
                        android:text="☰"
                        android:textColor="@android:color/white"
                        android:textSize="20sp"
                        android:textStyle="bold" />

                    <!-- ✨ Professional Gemini AI Button -->
                    <ImageView
                        android:id="@+id/cardAIVoice"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:background="@drawable/bg_panel_premium"
                        android:clickable="true"
                        android:focusable="true"
                        android:foreground="@drawable/focus_selector"
                        android:padding="8dp"
                        android:src="@drawable/ic_gemini_professional"
                        android:contentDescription="Gemini AI" />
                </LinearLayout>

                <!-- User Profiles Row -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="@string/users"
                    android:textColor="#C7B7D8"
                    android:textSize="12sp"
                    android:textStyle="bold" />

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/usersRecyclerView"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:clipToPadding="false" />

                <TextView
                    android:id="@+id/updateBadge"
                    android:layout_width="match_parent"
                    android:layout_height="34dp"
                    android:layout_marginTop="@dimen/margin_top_sm"
                    android:background="@drawable/bg_button_primary"
                    android:clickable="true"
                    android:focusable="true"
                    android:focusableInTouchMode="true"
                    android:foreground="@drawable/focus_selector"
                    android:gravity="center"
                    android:text="🔄 تحديث جديد متاح"
                    android:textColor="@android:color/white"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:visibility="gone" />

                <!-- ⏰ بانر تنبيه قرب انتهاء الاشتراك -->
                <TextView
                    android:id="@+id/expiryBanner"
                    android:layout_width="match_parent"
                    android:layout_height="34dp"
                    android:layout_marginTop="@dimen/margin_top_sm"
                    android:background="@drawable/bg_gold_btn"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center"
                    android:text=""
                    android:textColor="@color/gold_btn_text"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:visibility="gone" />

                <!-- Info Bars -->
                <TextView
                    android:id="@+id/loggedInText"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/info_bar_height"
                    android:layout_marginTop="@dimen/margin_top_sm"
                    android:background="@drawable/bg_panel"
                    android:ellipsize="end"
                    android:gravity="center"
                    android:maxLines="1"
                    android:text="Logged In"
                    android:textColor="@android:color/white"
                    android:textSize="@dimen/info_bar_text" />

                <TextView
                    android:id="@+id/expiryText"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/expiry_height"
                    android:layout_marginTop="@dimen/margin_top_sm"
                    android:background="@drawable/bg_panel"
                    android:ellipsize="end"
                    android:gravity="center"
                    android:maxLines="1"
                    android:text="Expiry"
                    android:textColor="@android:color/white"
                    android:textSize="@dimen/expiry_text" />

                <TextView
                    android:id="@+id/lastWatchedButton"
                    android:visibility="gone"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/info_bar_height"
                    android:layout_marginTop="@dimen/margin_top_sm"
                    android:background="@drawable/bg_panel_premium"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="@drawable/focus_selector"
                    android:gravity="center"
                    android:text="@string/continue_watching"
                    android:textColor="@android:color/white"
                    android:textSize="@dimen/info_bar_text" />

                <TextView
                    android:id="@+id/updatedText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/margin_top_xs"
                    android:gravity="center"
                    android:text="@string/last_update"
                    android:textColor="#C7B7D8"
                    android:textSize="12sp" />


                <!-- Quick Actions Row -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="40dp" android:layout_marginTop="@dimen/margin_top_sm" android:gravity="center" android:orientation="horizontal">
                    <LinearLayout android:id="@+id/toolbarSettingsTop" android:layout_width="0dp" android:layout_height="match_parent" android:layout_marginEnd="6dp" android:layout_weight="1" android:background="@drawable/bg_settings_btn" android:clickable="true" android:focusable="true" android:foreground="@drawable/focus_selector" android:gravity="center"><TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/settings_btn" android:textColor="@android:color/white" android:textSize="12sp" android:textStyle="bold" /></LinearLayout>
                    <LinearLayout android:id="@+id/toolbarUsersTop" android:layout_width="0dp" android:layout_height="match_parent" android:layout_marginStart="6dp" android:layout_weight="1" android:background="@drawable/bg_update_btn" android:clickable="true" android:focusable="true" android:foreground="@drawable/focus_selector" android:gravity="center"><TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/users_btn" android:textColor="@android:color/white" android:textSize="12sp" android:textStyle="bold" /></LinearLayout>
                </LinearLayout>
                <!-- Live Card -->
                <LinearLayout
                    android:id="@+id/cardLive"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/card_live_height"
                    android:layout_marginTop="@dimen/margin_top_xl"
                    android:background="@drawable/bg_card_live"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="@drawable/focus_selector"
                    android:gravity="center_vertical"
                    android:nextFocusUp="@id/menuButton"
                    android:nextFocusDown="@id/cardMovies"
                    android:orientation="horizontal"
                    android:padding="@dimen/card_padding">

                    <TextView
                        android:layout_width="@dimen/card_icon_width"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:text="▣"
                        android:textColor="@android:color/white"
                        android:textSize="@dimen/card_icon_text" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/live_tv"
                            android:textColor="@android:color/white"
                            android:textSize="@dimen/card_title"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/liveCount"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/margin_top_xs"
                            android:text="0"
                            android:textColor="@android:color/white"
                            android:textSize="@dimen/card_count" />
                    </LinearLayout>
                </LinearLayout>

                <!-- Movies Card -->
                <LinearLayout
                    android:id="@+id/cardMovies"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/card_media_height"
                    android:layout_marginTop="@dimen/margin_top_lg"
                    android:background="@drawable/bg_card_movie"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="@drawable/focus_selector"
                    android:gravity="center_vertical"
                    android:nextFocusUp="@id/cardLive"
                    android:nextFocusDown="@id/cardSeries"
                    android:orientation="horizontal"
                    android:padding="@dimen/card_padding">

                    <TextView
                        android:layout_width="@dimen/card_icon_width"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:text="▶"
                        android:textColor="@android:color/white"
                        android:textSize="@dimen/card_media_icon_text" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/movies"
                            android:textColor="@android:color/white"
                            android:textSize="@dimen/card_media_title"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/movieCount"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/margin_top_xs"
                            android:text="0"
                            android:textColor="@android:color/white"
                            android:textSize="@dimen/card_count" />
                    </LinearLayout>
                </LinearLayout>

                <!-- Series Card -->
                <LinearLayout
                    android:id="@+id/cardSeries"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/card_media_height"
                    android:layout_marginTop="@dimen/margin_top_lg"
                    android:background="@drawable/bg_card_series"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="@drawable/focus_selector"
                    android:gravity="center_vertical"
                    android:nextFocusUp="@id/cardMovies"
                    android:nextFocusDown="@id/backToHomeButton"
                    android:orientation="horizontal"
                    android:padding="@dimen/card_padding">

                    <TextView
                        android:layout_width="@dimen/card_icon_width"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:text="▤"
                        android:textColor="@android:color/white"
                        android:textSize="@dimen/card_media_icon_text" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/series"
                            android:textColor="@android:color/white"
                            android:textSize="@dimen/card_media_title"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/seriesCount"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/margin_top_xs"
                            android:text="0"
                            android:textColor="@android:color/white"
                            android:textSize="@dimen/card_count" />
                    </LinearLayout>
                </LinearLayout>



                <!-- Matches Card -->
                <LinearLayout android:id="@+id/cardMatches" android:layout_width="match_parent" android:layout_height="@dimen/card_media_height" android:layout_marginTop="@dimen/margin_top_lg" android:background="@drawable/bg_card_matches" android:clickable="true" android:focusable="true" android:foreground="@drawable/focus_selector" android:gravity="center_vertical" android:nextFocusUp="@id/cardSeries" android:nextFocusDown="@id/backToHomeButton" android:orientation="horizontal" android:padding="@dimen/card_padding"><TextView android:layout_width="@dimen/card_icon_width" android:layout_height="wrap_content" android:gravity="center" android:text="⚽" android:textColor="@android:color/white" android:textSize="@dimen/card_media_icon_text" /><LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical"><TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/matches_title" android:textColor="@android:color/white" android:textSize="@dimen/card_media_title" android:textStyle="bold" /><TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="@dimen/margin_top_xs" android:text="@string/todays_matches" android:textColor="@android:color/white" android:textSize="@dimen/card_count" /></LinearLayout></LinearLayout>

                <!-- Back to Home Button -->
                <LinearLayout
                    android:id="@+id/backToHomeButton"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:layout_marginTop="@dimen/margin_top_lg"
                    android:background="@drawable/bg_panel_premium"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="@drawable/focus_selector"
                    android:gravity="center"
                    android:nextFocusUp="@id/cardSeries"
                    android:nextFocusDown="@id/whatsappButton"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/back_to_home_main"
                        android:textColor="@android:color/white"
                        android:textSize="16sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <!-- Footer -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/margin_top_xxl"
                    android:gravity="center"
                    android:text="@string/developed_by"
                    android:textColor="#C7B7D8"
                    android:textSize="@dimen/footer_text" />

                <!-- Whatsapp -->
                <LinearLayout
                    android:id="@+id/whatsappButton"
                    android:visibility="gone"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/whatsapp_height"
                    android:layout_marginTop="@dimen/margin_top_xl"
                    android:background="@drawable/bg_whatsapp"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="@drawable/focus_selector"
                    android:gravity="center"
                    android:nextFocusUp="@id/backToHomeButton"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="10dp"
                        android:text="✆"
                        android:textColor="@android:color/white"
                        android:textSize="@dimen/whatsapp_icon" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/whatsapp_contact"
                        android:textColor="@android:color/white"
                        android:textSize="@dimen/whatsapp_text"
                        android:textStyle="bold" />
                </LinearLayout>

                <!-- Bottom Toolbar -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:visibility="gone"
                    android:layout_marginTop="@dimen/margin_top_lg"
                    android:gravity="center"
                    android:orientation="horizontal">

                    <LinearLayout
                        android:id="@+id/toolbarSettings"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_marginEnd="8dp"
                        android:layout_weight="1"
                        android:background="@drawable/bg_panel"
                        android:clickable="true"
                        android:focusable="true"
                        android:foreground="@drawable/focus_selector"
                        android:gravity="center"
                        android:orientation="horizontal">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/settings_btn"
                            android:textColor="@android:color/white"
                            android:textSize="12sp"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/toolbarUsers"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_marginStart="8dp"
                        android:layout_weight="1"
                        android:background="@drawable/bg_panel"
                        android:clickable="true"
                        android:focusable="true"
                        android:foreground="@drawable/focus_selector"
                        android:gravity="center"
                        android:orientation="horizontal">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/users_btn"
                            android:textColor="@android:color/white"
                            android:textSize="12sp"
                            android:textStyle="bold" />
                    </LinearLayout>
                </LinearLayout>

                <!-- Loading Row -->
                <LinearLayout
                    android:id="@+id/loadingRow"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:layout_marginTop="@dimen/margin_top_lg"
                    android:gravity="center"
                    android:orientation="horizontal"
                    android:visibility="gone">

                    <ProgressBar
                        android:id="@+id/progressBar"
                        android:layout_width="@dimen/loading_size"
                        android:layout_height="@dimen/loading_size" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="@dimen/margin_top_sm"
                        android:text="@string/loading_dots"
                        android:textColor="@android:color/white"
                        android:textSize="@dimen/loading_text"
                        android:textStyle="bold" />
                </LinearLayout>
            </LinearLayout>
        </ScrollView>

        <!-- 🎙️ AI Voice Overlay -->
        <include
            android:id="@+id/voiceOverlay"
            layout="@layout/voice_overlay"
            android:visibility="gone" />

        <!-- Loading Overlay with Dhikr -->
        <FrameLayout
            android:id="@+id/loadingOverlay"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="#AA000000"
            android:clickable="true"
            android:focusable="false"
            android:visibility="gone">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:gravity="center"
                android:orientation="vertical"
                android:padding="24dp">

                <ProgressBar
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:layout_marginBottom="16dp" />

                <TextView
                    android:id="@+id/loadingTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="8dp"
                    android:text="@string/loading_adhkar_title"
                    android:textColor="#FFD700"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/loadingText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:lineSpacingExtra="6dp"
                    android:text="سبحان الله وبحمده"
                    android:textColor="#FFFFFF"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/loadingRef"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:gravity="center"
                    android:text="التسبيح 33 مرة"
                    android:textColor="#C7B7D8"
                    android:textSize="12sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:gravity="center"
                    android:text="@string/loading_adhkar_subtitle"
                    android:textColor="#FFFFFF"
                    android:textSize="14sp"
                    android:textStyle="italic" />
            </LinearLayout>
        </FrameLayout>
    </FrameLayout>

    <!-- Navigation Drawer (same as UserList) -->
    <LinearLayout
        android:id="@+id/drawerMenu"
        android:layout_width="280dp"
        android:layout_height="match_parent"
        android:layout_gravity="end"
        android:background="#121228"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:gravity="center"
            android:text="LATCHI IPTV"
            android:textColor="#FFD700"
            android:textSize="22sp"
            android:textStyle="bold" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginVertical="16dp"
            android:background="#2d2d44" />
        <TextView
            android:id="@+id/drawerSupport"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginBottom="8dp"
            android:background="@drawable/bg_panel_premium_focusable"
            android:clickable="true"
            android:focusable="true"
            android:foreground="@drawable/focus_selector"
            android:gravity="center_vertical"
            android:paddingHorizontal="16dp"
            android:text="📞 الدعم الفني"
            android:textColor="@android:color/white"
            android:textSize="16sp"
            android:textStyle="bold" />


        <TextView
            android:id="@+id/drawerMatches"
            android:nextFocusUp="@id/drawerMatches"
            android:nextFocusDown="@id/drawerPrayer"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginBottom="8dp"
            android:background="@drawable/bg_panel_premium_focusable"
            android:clickable="true"
            android:focusable="true"
            android:foreground="@drawable/focus_selector"
            android:gravity="center_vertical"
            android:paddingHorizontal="16dp"
            android:text="@string/drawer_matches"
            android:textColor="@android:color/white"
            android:textSize="16sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/drawerPrayer"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginBottom="8dp"
            android:background="@drawable/bg_panel_premium_focusable"
            android:clickable="true"
            android:focusable="true"
            android:foreground="@drawable/focus_selector"
            android:gravity="center_vertical"
            android:paddingHorizontal="16dp"
            android:text="@string/drawer_prayer"
            android:textColor="@android:color/white"
            android:textSize="16sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/drawerPricing"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginBottom="8dp"
            android:background="@drawable/bg_panel_premium_focusable"
            android:clickable="true"
            android:focusable="true"
            android:foreground="@drawable/focus_selector"
            android:gravity="center_vertical"
            android:paddingHorizontal="16dp"
            android:text="@string/drawer_pricing"
            android:textColor="@android:color/white"
            android:textSize="16sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/drawerThemeSettings"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginBottom="8dp"
            android:background="@drawable/bg_panel_premium_focusable"
            android:clickable="true"
            android:focusable="true"
            android:foreground="@drawable/focus_selector"
            android:gravity="center_vertical"
            android:paddingHorizontal="16dp"
            android:text="@string/theme_settings"
            android:textColor="@android:color/white"
            android:textSize="16sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/drawerSettings"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginBottom="8dp"
            android:background="@drawable/bg_panel_premium_focusable"
            android:clickable="true"
            android:focusable="true"
            android:foreground="@drawable/focus_selector"
            android:gravity="center_vertical"
            android:paddingHorizontal="16dp"
            android:text="@string/drawer_settings"
            android:textColor="@android:color/white"
            android:textSize="16sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/drawerAbout"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginBottom="8dp"
            android:background="@drawable/bg_panel_premium_focusable"
            android:clickable="true"
            android:focusable="true"
            android:foreground="@drawable/focus_selector"
            android:gravity="center_vertical"
            android:paddingHorizontal="16dp"
            android:text="@string/drawer_about"
            android:textColor="@android:color/white"
            android:textSize="16sp"
            android:textStyle="bold" />


        <TextView
            android:id="@+id/drawerShare"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginBottom="8dp"
