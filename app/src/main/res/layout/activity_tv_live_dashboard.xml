<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/mainDashboardContainer"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_app"
    android:orientation="horizontal"
    android:padding="12dp">

    <!-- 1. Column 1: الفئات (Categories) — Weight: 0.24 -->
    <LinearLayout
        android:id="@+id/panelCategories"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="0.24"
        android:background="@drawable/bg_panel"
        android:orientation="vertical"
        android:padding="10dp"
        android:layout_marginEnd="6dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:text="📁 الفئات / Groups"
            android:textColor="#FFD700"
            android:textSize="15sp"
            android:textStyle="bold"
            android:layout_marginBottom="10dp" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recyclerCategories"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:clipToPadding="false" />
    </LinearLayout>

    <!-- 2. Column 2: القنوات والحروف (Channels + A-Z) — Weight: 0.36 -->
    <LinearLayout
        android:id="@+id/panelChannels"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="0.36"
        android:background="@drawable/bg_panel"
        android:orientation="vertical"
        android:padding="10dp"
        android:layout_marginHorizontal="6dp">

        <TextView
            android:id="@+id/txtFilterHint"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:text="📺 قائمة القنوات (الكل)"
            android:textColor="#7FE6FF"
            android:textSize="15sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp" />

        <!-- Universal Alphabet Horizontal Scroll Bar -->
        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:scrollbars="none"
            android:layout_marginBottom="8dp">

            <LinearLayout
                android:id="@+id/containerAlphabet"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:orientation="horizontal"
                android:gravity="center_vertical" />
        </HorizontalScrollView>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recyclerChannels"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:clipToPadding="false" />
    </LinearLayout>

    <!-- 3. Column 3: المعاينة المباشرة والتفاصيل (Video Preview) — Weight: 0.40 -->
    <LinearLayout
        android:id="@+id/panelPlayer"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="0.40"
        android:background="@drawable/bg_panel"
        android:orientation="vertical"
        android:padding="12dp"
        android:gravity="center_horizontal"
        android:layout_marginStart="6dp">

        <TextView
            android:id="@+id/txtChannelTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:text="Channel Title"
            android:textColor="#FFD700"
            android:textSize="20sp"
            android:textStyle="bold"
            android:singleLine="true"
            android:ellipsize="end" />

        <TextView
            android:id="@+id/txtCategorySubtitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:text="Category Name"
            android:textColor="#C7B7D8"
            android:textSize="13sp"
            android:layout_marginTop="2dp"
            android:singleLine="true" />

        <TextView
            android:id="@+id/txtEpgInfo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:text="EPG: جاري التحميل..."
            android:textColor="#39FF8B"
            android:textSize="13sp"
            android:layout_marginTop="6dp"
            android:layout_marginBottom="10dp"
            android:maxLines="2"
            android:ellipsize="end" />

        <!-- Actual Video Frame -->
        <FrameLayout
            android:id="@+id/frameVideo"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:background="#000000"
            android:clickable="true"
            android:focusable="true"
            android:foreground="@drawable/focus_ring_vip"
            android:layout_marginVertical="6dp"
            android:elevation="6dp">

            <com.google.android.exoplayer2.ui.PlayerView
                android:id="@+id/viewPlayer"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                app:show_buffering="never"
                app:use_controller="false"
                app:resize_mode="fit" />
        </FrameLayout>

        <TextView
            android:id="@+id/txtDetailsBottom"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:text="▶ البث المباشر مستمر"
            android:textColor="#FFFFFF"
            android:textSize="12sp"
            android:layout_marginTop="8dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:text="💡 اضغط OK على المشغل لتكبير الشاشة (Fullscreen)"
            android:textColor="#8891B8"
            android:textSize="11sp"
            android:layout_marginTop="4dp" />
    </LinearLayout>
</LinearLayout>
