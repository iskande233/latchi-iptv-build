<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="72dp"
    android:layout_marginVertical="6dp"
    android:layout_marginHorizontal="8dp"
    android:background="@drawable/bg_user_card"
    android:clickable="true"
    android:focusable="true"
    android:foreground="@drawable/focus_selector"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:paddingHorizontal="16dp"
    android:elevation="4dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="👤"
        android:textSize="26sp"
        android:layout_marginEnd="14dp" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical"
        android:gravity="center_vertical">

        <TextView
            android:id="@+id/profileTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:ellipsize="end"
            android:maxLines="1"
            android:text="اسم المستخدم"
            android:textColor="#FFFFFF"
            android:textSize="17sp"
            android:textStyle="bold" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/profileCode"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Code: 123456"
                android:textColor="#FFD700"
                android:textSize="12sp"
                android:textStyle="bold"
                android:layout_marginEnd="10dp" />

            <TextView
                android:id="@+id/profileActiveMarker"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="#16A34A"
                android:paddingHorizontal="8dp"
                android:paddingVertical="2dp"
                android:text="✅ نشط حالياً"
                android:textColor="#000000"
                android:textSize="10sp"
                android:textStyle="bold" />
        </LinearLayout>
    </LinearLayout>

    <ImageView
        android:id="@+id/deleteButton"
        android:layout_width="44dp"
        android:layout_height="44dp"
        android:clickable="true"
        android:focusable="false"
        android:padding="8dp"
        android:src="@android:drawable/ic_menu_delete"
        android:tint="#FF4444" />
</LinearLayout>
