<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="76dp"
    android:layout_marginVertical="6dp"
    android:layout_marginHorizontal="8dp"
    android:background="@drawable/bg_app"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:elevation="4dp"
    android:clipChildren="false">

    <!-- 1. زر فتح الحساب (يأخذ الجزء الأكبر) -->
    <LinearLayout
        android:id="@+id/cardOpenProfile"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:background="@drawable/bg_user_card"
        android:clickable="true"
        android:focusable="true"
        android:foreground="@drawable/focus_selector"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="16dp"
        android:layout_marginEnd="6dp"
        android:nextFocusRight="@+id/deleteButton">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="👤"
            android:textSize="26sp"
            android:layout_marginEnd="14dp" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/profileTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:ellipsize="end"
                android:maxLines="1"
                android:text="اسم المستخدم"
                android:textColor="#FFFFFF"
                android:textSize="17sp"
                android:textStyle="bold" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:id="@+id/profileCode"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Code: 123456"
                    android:textColor="#FFD700"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:layout_marginEnd="10dp" />

                <TextView
                    android:id="@+id/profileActiveMarker"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="#16A34A"
                    android:paddingHorizontal="8dp"
                    android:paddingVertical="2dp"
                    android:text="✅ نشط حالياً"
                    android:textColor="#000000"
                    android:textSize="10sp"
                    android:textStyle="bold" />
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>

    <!-- 2. زر حذف الحساب المستقل (قابل للتركيز بالريموت كنترول) -->
    <ImageView
        android:id="@+id/deleteButton"
        android:layout_width="66dp"
        android:layout_height="match_parent"
        android:background="@drawable/bg_panel_premium_focusable"
        android:clickable="true"
        android:focusable="true"
        android:foreground="@drawable/focus_selector"
        android:gravity="center"
        android:padding="16dp"
        android:src="@android:drawable/ic_menu_delete"
        android:tint="#FF4444"
        android:nextFocusLeft="@+id/cardOpenProfile"
        android:contentDescription="حذف الحساب" />
</LinearLayout>
