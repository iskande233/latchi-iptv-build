<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_app"
    android:orientation="horizontal">

    <!-- Left: Channel List -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:orientation="vertical"
        android:padding="8dp">

        <!-- Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/tvBackButton"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:gravity="center"
                android:paddingHorizontal="12dp"
                android:text="← Back"
                android:textColor="@android:color/white"
                android:textSize="14sp"
                android:focusable="true"
                android:clickable="true"
                android:foreground="@drawable/focus_selector" />

            <ImageView
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:layout_marginStart="8dp"
                android:scaleType="fitCenter"
                android:src="@drawable/ic_tv" />

            <View android:layout_width="0dp" android:layout_height="0dp" android:layout_weight="1" />

            <TextView
                android:id="@+id/tvClock"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#C7B7D8"
                android:textSize="12sp" />
        </LinearLayout>

        <!-- Category selector -->
        <TextView
            android:id="@+id/tvCategoryButton"
            android:layout_width="match_parent"
            android:layout_height="40dp"
            android:layout_marginTop="4dp"
            android:background="@drawable/bg_button_primary"
            android:focusable="true"
            android:clickable="true"
            android:foreground="@drawable/focus_selector"
            android:gravity="center"
            android:text="All"
            android:textColor="@android:color/white"
            android:textSize="14sp"
            android:textStyle="bold" />

        <!-- Channel list -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/tvChannelList"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:layout_marginTop="4dp"
            android:clipToPadding="false" />
    </LinearLayout>

    <!-- Right: Video Preview -->
    <FrameLayout
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1.5"
        android:padding="8dp">

        <com.google.android.exoplayer2.ui.PlayerView
            android:id="@+id/tvPreviewPlayer"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            xmlns:app="http://schemas.android.com/apk/res-auto"
            app:show_buffering="never"
            android:background="#000000" />

        <!-- Channel info overlay -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom"
            android:background="#99000000"
            android:orientation="vertical"
            android:padding="12dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Live TV"
                android:textColor="#FF4444"
                android:textSize="11sp"
                android:textStyle="bold"
                android:background="#33FF0000"
                android:paddingHorizontal="8dp"
                android:paddingVertical="2dp" />

            <TextView
                android:id="@+id/tvChannelName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:textColor="@android:color/white"
                android:textSize="16sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvChannelInfo"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="No Information"
                android:textColor="#C7B7D8"
                android:textSize="11sp" />
        </LinearLayout>
    </FrameLayout>
</LinearLayout>
