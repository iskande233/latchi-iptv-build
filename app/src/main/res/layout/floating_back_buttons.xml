<?xml version="1.0" encoding="utf-8"?>
<!-- 🎯 Universal Professional Floating Back Button (single, no duplicate top button) -->
<merge xmlns:android="http://schemas.android.com/apk/res/android">

    <View
        android:id="@+id/fabBackTopRight"
        android:layout_width="1dp"
        android:layout_height="1dp"
        android:visibility="gone" />

    <LinearLayout
        android:id="@+id/fabBackBottomRight"
        android:layout_width="92dp"
        android:layout_height="48dp"
        android:layout_gravity="bottom|end"
        android:layout_marginBottom="24dp"
        android:layout_marginEnd="18dp"
        android:background="@drawable/bg_back_professional"
        android:clickable="true"
        android:focusable="true"
        android:foreground="@drawable/focus_selector"
        android:gravity="center"
        android:orientation="horizontal"
        android:elevation="14dp">

        <ImageView
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:src="@drawable/ic_back_professional"
            android:contentDescription="رجوع" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="6dp"
            android:text="رجوع"
            android:textColor="#FFD700"
            android:textSize="13sp"
            android:textStyle="bold" />
    </LinearLayout>
</merge>
