<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/drawerLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_app">

    <!-- Main TV Content Frame -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:padding="28dp">

            <!-- ===== Center Clock Widget with Active Seconds (في الوسط بالثواني) ===== -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:orientation="vertical">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_vip_clock_widget"
                    android:gravity="center"
                    android:orientation="horizontal"
                    android:paddingHorizontal="26dp"
                    android:paddingVertical="10dp"
                    android:elevation="12dp">

                    <TextView
                        android:id="@+id/clockTimeText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="monospace"
                        android:paddingEnd="12dp"
                        android:text="00:00:00"
                        android:textColor="#FFD700"
                        android:textSize="22sp"
                        android:textStyle="bold" />

                    <View
                        android:layout_width="1dp"
                        android:layout_height="22dp"
                        android:layout_marginHorizontal="8dp"
                        android:background="#66FFD700" />

                    <TextView
                        android:id="@+id/clockDateText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:paddingStart="4dp"
                        android:text="— —"
                        android:textColor="#F2F4FF"
                        android:textSize="14sp"
                        android:textStyle="bold" />
                </LinearLayout>
            </LinearLayout>

            <!-- ===== Top Info Bars: Account Expiry & Name & Last Server Update ===== -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:gravity="center_horizontal"
                android:orientation="vertical">

                <!-- Row 1: Logged In (User Name) & Expiry Date -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="38dp"
                    android:background="@drawable/bg_vip_grid_card"
                    android:gravity="center"
                    android:orientation="horizontal"
                    android:paddingHorizontal="16dp"
                    android:elevation="8dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Logged In / Expiry:  "
                        android:textColor="#7FE6FF"
                        android:textSize="12sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/loggedInText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="User Name"
                        android:textColor="#FFFFFF"
                        android:textSize="13sp"
                        android:textStyle="bold" />

                    <View
                        android:layout_width="1dp"
                        android:layout_height="16dp"
                        android:layout_marginHorizontal="10dp"
                        android:background="#3d3d5c" />

                    <TextView
                        android:id="@+id/expiryText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="2027-12-30"
                        android:textColor="#39FF8B"
                        android:textSize="13sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="   :اسم المستخدم / الصلاحية"
                        android:textColor="#7FE6FF"
                        android:textSize="12sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <!-- Row 2: Last Server Update Option -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    android:layout_marginTop="6dp"
                    android:background="@drawable/bg_vip_grid_card"
                    android:gravity="center"
                    android:orientation="horizontal"
                    android:paddingHorizontal="16dp"
                    android:elevation="6dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Last Server Update: "
                        android:textColor="#A5B4FC"
                        android:textSize="11sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/updatedText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:paddingHorizontal="6dp"
                        android:text="2026-06-16 14:30"
                        android:textColor="#FFD700"
                        android:textSize="12sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text=" :آخر تحديث للسيرفر"
                        android:textColor="#A5B4FC"
                        android:textSize="11sp"
                        android:textStyle="bold" />
                </LinearLayout>
            </LinearLayout>

            <TextView
                android:id="@+id/updateBadge"
                android:layout_width="match_parent"
                android:layout_height="34dp"
                android:layout_marginTop="10dp"
                android:background="@drawable/bg_button_primary"
                android:clickable="true"
                android:focusable="true"
                android:foreground="@drawable/focus_ring_vip"
                android:gravity="center"
                android:text="🔄 تحديث تطبيق LATCHI IPTV متاح"
                android:textColor="@android:color/white"
                android:textSize="13sp"
                android:textStyle="bold"
                android:visibility="gone" />

            <!-- ⏰ بانر تنبيه انتهاء الاشتراك -->
            <TextView
                android:id="@+id/expiryBanner"
                android:layout_width="match_parent"
                android:layout_height="34dp"
                android:layout_marginTop="8dp"
                android:background="@drawable/bg_gold_btn"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center"
                android:text=""
                android:textColor="#000000"
                android:textSize="13sp"
                android:textStyle="bold"
                android:visibility="gone" />

            <View
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1" />

            <!-- 🚀 Absolute Original Cropped Transparent Icons (5 Up / 3 Down) 🚀 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:orientation="vertical"
                android:paddingVertical="12dp"
                android:clipChildren="false">

                <!-- 1. Top Row: Exactly 5 Cards Up (فوق خمسه الفوق) -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:orientation="horizontal"
                    android:clipChildren="false">

                    <!-- Item 1: LIVE -->
                    <FrameLayout
                        android:id="@+id/cardLive"
                        android:layout_width="164dp"
                        android:layout_height="96dp"
                        android:layout_marginHorizontal="8dp"
                        android:background="@null"
                        android:clickable="true"
                        android:focusable="true">

                        <ImageView
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:scaleType="fitCenter"
                            android:src="@drawable/tv_card_live"
                            android:contentDescription="البث المباشر" />
                    </FrameLayout>

                    <!-- Item 2: FILMS / MOVIES -->
                    <FrameLayout
                        android:id="@+id/cardMovies"
                        android:layout_width="164dp"
                        android:layout_height="96dp"
                        android:layout_marginHorizontal="8dp"
                        android:background="@null"
                        android:clickable="true"
                        android:focusable="true">

                        <ImageView
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:scaleType="fitCenter"
                            android:src="@drawable/tv_card_films"
                            android:contentDescription="الأفلام" />
                    </FrameLayout>

                    <!-- Item 3: SERIES -->
                    <FrameLayout
                        android:id="@+id/cardSeries"
                        android:layout_width="164dp"
                        android:layout_height="96dp"
                        android:layout_marginHorizontal="8dp"
                        android:background="@null"
                        android:clickable="true"
                        android:focusable="true">

                        <ImageView
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:scaleType="fitCenter"
                            android:src="@drawable/tv_card_series"
                            android:contentDescription="المسلسلات" />
                    </FrameLayout>

                    <!-- Item 4: MATCHES -->
                    <FrameLayout
                        android:id="@+id/cardMatches"
                        android:layout_width="164dp"
                        android:layout_height="96dp"
                        android:layout_marginHorizontal="8dp"
                        android:background="@null"
                        android:clickable="true"
                        android:focusable="true">

                        <ImageView
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:scaleType="fitCenter"
                            android:src="@drawable/tv_card_matches"
                            android:contentDescription="المباريات" />
                    </FrameLayout>

                    <!-- Item 5: beIN SPORTS -->
                    <FrameLayout
                        android:id="@+id/cardBeInSports"
                        android:layout_width="164dp"
                        android:layout_height="96dp"
                        android:layout_marginHorizontal="8dp"
                        android:background="@null"
                        android:clickable="true"
                        android:focusable="true">

                        <ImageView
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:scaleType="fitCenter"
                            android:src="@drawable/tv_card_bein"
                            android:contentDescription="بي إن سبورت" />
                    </FrameLayout>
                </LinearLayout>

                <!-- 2. Bottom Row: Exactly 3 Cards Down (ثلاثه تحت) -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp"
                    android:gravity="center"
                    android:orientation="horizontal"
                    android:clipChildren="false">

                    <!-- Item 6: ACCOUNTS -->
                    <FrameLayout
                        android:id="@+id/cardAccounts"
                        android:layout_width="164dp"
                        android:layout_height="96dp"
                        android:layout_marginHorizontal="12dp"
                        android:background="@null"
                        android:clickable="true"
                        android:focusable="true">

                        <ImageView
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:scaleType="fitCenter"
                            android:src="@drawable/tv_card_accounts"
                            android:contentDescription="الحسابات" />
                    </FrameLayout>

                    <!-- Item 7: THEME (Wallpapers) -->
                    <FrameLayout
                        android:id="@+id/cardTheme"
                        android:layout_width="164dp"
                        android:layout_height="96dp"
                        android:layout_marginHorizontal="12dp"
                        android:background="@null"
                        android:clickable="true"
                        android:focusable="true">

                        <ImageView
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:scaleType="fitCenter"
                            android:src="@drawable/tv_card_theme"
                            android:contentDescription="خلفيات الشاشة" />
                    </FrameLayout>

                    <!-- Item 8: SETTINGS -->
                    <FrameLayout
                        android:id="@+id/cardSettings"
                        android:layout_width="164dp"
                        android:layout_height="96dp"
                        android:layout_marginHorizontal="12dp"
                        android:background="@null"
                        android:clickable="true"
                        android:focusable="true">

                        <ImageView
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:scaleType="fitCenter"
                            android:src="@drawable/tv_card_settings"
                            android:contentDescription="الإعدادات" />
                    </FrameLayout>
                </LinearLayout>
            </LinearLayout>

            <TextView
                android:id="@+id/lastWatchedButton"
                android:layout_width="match_parent"
                android:layout_height="40dp"
                android:layout_marginTop="16dp"
                android:background="@drawable/bg_vip_grid_card"
                android:clickable="true"
                android:focusable="true"
                android:foreground="@drawable/focus_ring_vip"
                android:gravity="center"
                android:text="@string/continue_watching"
                android:textColor="@android:color/white"
                android:textSize="14sp"
                android:textStyle="bold"
                android:visibility="gone" />

            <!-- Sub views hidden -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/usersRecyclerView"
                android:layout_width="1dp"
                android:layout_height="1dp"
                android:visibility="gone" />

            <LinearLayout
                android:id="@+id/loadingRow"
                android:layout_width="1dp"
                android:layout_height="1dp"
                android:visibility="gone" />
        </LinearLayout>
    </FrameLayout>

    <!-- ===== Navigation Drawer Menu ===== -->
    <LinearLayout
        android:id="@+id/drawerMenu"
        android:layout_width="280dp"
        android:layout_height="match_parent"
        android:layout_gravity="end"
        android:background="#121228"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:gravity="center"
            android:text="LATCHI IPTV"
            android:textColor="#FFD700"
            android:textSize="22sp"
            android:textStyle="bold" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginVertical="16dp"
            android:background="#2d2d44" />

        <TextView
            android:id="@+id/drawerSupport"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginBottom="8dp"
            android:background="@drawable/bg_vip_grid_card"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center_vertical"
            android:paddingHorizontal="16dp"
            android:text="📞 الدعم الفني"
            android:textColor="#39FF8B"
            android:textSize="15sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/drawerMatches"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginBottom="8dp"
            android:background="@drawable/bg_panel_premium_focusable"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center_vertical"
            android:paddingHorizontal="16dp"
            android:text="@string/drawer_matches"
            android:textColor="@android:color/white"
            android:textSize="16sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/drawerPrayer"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginBottom="8dp"
            android:background="@drawable/bg_panel_premium_focusable"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center_vertical"
            android:paddingHorizontal="16dp"
            android:text="@string/drawer_prayer"
            android:textColor="@android:color/white"
            android:textSize="16sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/drawerPricing"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginBottom="8dp"
            android:background="@drawable/bg_panel_premium_focusable"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center_vertical"
            android:paddingHorizontal="16dp"
            android:text="@string/drawer_pricing"
            android:textColor="@android:color/white"
            android:textSize="16sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/drawerThemeSettings"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginBottom="8dp"
            android:background="@drawable/bg_panel_premium_focusable"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center_vertical"
            android:paddingHorizontal="16dp"
            android:text="@string/theme_settings"
            android:textColor="@android:color/white"
            android:textSize="16sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/drawerSettings"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginBottom="8dp"
            android:background="@drawable/bg_panel_premium_focusable"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center_vertical"
            android:paddingHorizontal="16dp"
            android:text="@string/drawer_settings"
            android:textColor="@android:color/white"
            android:textSize="16sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/drawerAbout"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginBottom="8dp"
            android:background="@drawable/bg_panel_premium_focusable"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center_vertical"
            android:paddingHorizontal="16dp"
            android:text="@string/drawer_about"
            android:textColor="@android:color/white"
            android:textSize="16sp"
            android:textStyle="bold" />

        <View
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:gravity="center"
            android:text="LATCHI IPTV VIP"
            android:textColor="#666666"
            android:textSize="12sp" />
    </LinearLayout>

    <FrameLayout
        android:id="@+id/loadingOverlay"
        android:layout_width="1dp"
        android:layout_height="1dp"
        android:visibility="gone" />

    <FrameLayout
        android:id="@+id/voiceOverlay"
        android:layout_width="1dp"
        android:layout_height="1dp"
        android:visibility="gone" />
</androidx.drawerlayout.widget.DrawerLayout>
