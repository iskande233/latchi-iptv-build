<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/drawerLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_app">

    <!-- Main TV Content -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:padding="24dp">

            <!-- ===== Top Clock & Header Row VIP ===== -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <ImageView
                    android:id="@+id/headerLogo"
                    android:layout_width="54dp"
                    android:layout_height="54dp"
                    android:scaleType="fitCenter"
                    android:src="@drawable/tv_logo" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="16dp"
                    android:text="LATCHI IPTV"
                    android:textColor="#FFD700"
                    android:textSize="22sp"
                    android:textStyle="bold" />

                <View
                    android:layout_width="0dp"
                    android:layout_height="1dp"
                    android:layout_weight="1" />

                <!-- 🕒 Clock Widget -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:orientation="horizontal"
                    android:background="@drawable/bg_vip_clock_widget"
                    android:paddingHorizontal="20dp"
                    android:paddingVertical="8dp">

                    <TextView
                        android:id="@+id/clockTimeText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="#FFD700"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:fontFamily="monospace"
                        android:text="--:--" />

                    <View
                        android:layout_width="1dp"
                        android:layout_height="18dp"
                        android:background="#66FFD700"
                        android:layout_marginHorizontal="10dp" />

                    <TextView
                        android:id="@+id/clockDateText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="#F2F4FF"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:text="— —" />
                </LinearLayout>

                <!-- ✨ Gemini AI Button -->
                <ImageView
                    android:id="@+id/cardAIVoice"
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:layout_marginStart="12dp"
                    android:background="@drawable/bg_vip_grid_card"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="@drawable/focus_ring_vip"
                    android:padding="8dp"
                    android:src="@drawable/ic_gemini_professional"
                    android:contentDescription="Gemini AI" />

                <!-- Hamburger Menu -->
                <TextView
                    android:id="@+id/menuButton"
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:layout_marginStart="10dp"
                    android:background="@drawable/bg_vip_grid_card"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="@drawable/focus_ring_vip"
                    android:gravity="center"
                    android:text="☰"
                    android:textColor="@android:color/white"
                    android:textSize="22sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <TextView
                android:id="@+id/updateBadge"
                android:layout_width="match_parent"
                android:layout_height="34dp"
                android:layout_marginTop="12dp"
                android:background="@drawable/bg_button_primary"
                android:clickable="true"
                android:focusable="true"
                android:foreground="@drawable/focus_ring_vip"
                android:gravity="center"
                android:text="🔄 تحديث جديد متاح"
                android:textColor="@android:color/white"
                android:textSize="13sp"
                android:textStyle="bold"
                android:visibility="gone" />

            <!-- ⏰ بانر تنبيه قرب انتهاء الاشتراك -->
            <TextView
                android:id="@+id/expiryBanner"
                android:layout_width="match_parent"
                android:layout_height="34dp"
                android:layout_marginTop="10dp"
                android:background="@drawable/bg_gold_btn"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center"
                android:text=""
                android:textColor="#000000"
                android:textSize="13sp"
                android:textStyle="bold"
                android:visibility="gone" />

            <!-- Info Bars -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="10dp">

                <TextView
                    android:id="@+id/loggedInText"
                    android:layout_width="0dp"
                    android:layout_height="38dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_vip_grid_card"
                    android:ellipsize="end"
                    android:gravity="center"
                    android:maxLines="1"
                    android:text="Logged In"
                    android:textColor="@android:color/white"
                    android:textSize="13sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/expiryText"
                    android:layout_width="0dp"
                    android:layout_height="38dp"
                    android:layout_weight="1"
                    android:layout_marginStart="10dp"
                    android:background="@drawable/bg_vip_grid_card"
                    android:ellipsize="end"
                    android:gravity="center"
                    android:maxLines="1"
                    android:text="Expiry"
                    android:textColor="@android:color/white"
                    android:textSize="13sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <TextView
                android:id="@+id/lastWatchedButton"
                android:visibility="gone"
                android:layout_width="match_parent"
                android:layout_height="40dp"
                android:layout_marginTop="10dp"
                android:background="@drawable/bg_vip_grid_card"
                android:clickable="true"
                android:focusable="true"
                android:foreground="@drawable/focus_ring_vip"
                android:gravity="center"
                android:text="@string/continue_watching"
                android:textColor="@android:color/white"
                android:textSize="14sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/updatedText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:gravity="center"
                android:text="@string/last_update"
                android:textColor="#A5B4FC"
                android:textSize="12sp" />

            <View
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1" />

            <!-- 🚀 Google TV / Android TV Sleek Transparent Single Horizontal Ribbon 🚀 -->
            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:clipToPadding="false"
                android:paddingVertical="16dp"
                android:scrollbars="none">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <!-- 1. LIVE TV -->
                    <FrameLayout
                        android:id="@+id/cardLive"
                        android:layout_width="160dp"
                        android:layout_height="90dp"
                        android:layout_marginHorizontal="10dp"
                        android:background="@null"
                        android:clickable="true"
                        android:focusable="true">

                        <ImageView
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:scaleType="fitCenter"
                            android:src="@drawable/tv_card_live"
                            android:contentDescription="البث المباشر" />

                        <TextView
                            android:id="@+id/liveCount"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="bottom|center_horizontal"
                            android:background="#99000000"
                            android:paddingHorizontal="8dp"
                            android:paddingVertical="2dp"
                            android:textColor="#39FF8B"
                            android:textSize="11sp"
                            android:textStyle="bold"
                            android:visibility="gone" />
                    </FrameLayout>

                    <!-- 2. MOVIES -->
                    <FrameLayout
                        android:id="@+id/cardMovies"
                        android:layout_width="160dp"
                        android:layout_height="90dp"
                        android:layout_marginHorizontal="10dp"
                        android:background="@null"
                        android:clickable="true"
                        android:focusable="true">

                        <ImageView
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:scaleType="fitCenter"
                            android:src="@drawable/tv_card_films"
                            android:contentDescription="الأفلام" />

                        <TextView
                            android:id="@+id/movieCount"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="bottom|center_horizontal"
                            android:background="#99000000"
                            android:paddingHorizontal="8dp"
                            android:paddingVertical="2dp"
                            android:textColor="#7FE6FF"
                            android:textSize="11sp"
                            android:textStyle="bold"
                            android:visibility="gone" />
                    </FrameLayout>

                    <!-- 3. SERIES -->
                    <FrameLayout
                        android:id="@+id/cardSeries"
                        android:layout_width="160dp"
                        android:layout_height="90dp"
                        android:layout_marginHorizontal="10dp"
                        android:background="@null"
                        android:clickable="true"
                        android:focusable="true">

                        <ImageView
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:scaleType="fitCenter"
                            android:src="@drawable/tv_card_series"
                            android:contentDescription="المسلسلات" />

                        <TextView
                            android:id="@+id/seriesCount"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="bottom|center_horizontal"
                            android:background="#99000000"
                            android:paddingHorizontal="8dp"
                            android:paddingVertical="2dp"
                            android:textColor="#FFD700"
                            android:textSize="11sp"
                            android:textStyle="bold"
                            android:visibility="gone" />
                    </FrameLayout>

                    <!-- 4. MATCHES -->
                    <FrameLayout
                        android:id="@+id/cardMatches"
                        android:layout_width="160dp"
                        android:layout_height="90dp"
                        android:layout_marginHorizontal="10dp"
                        android:background="@null"
                        android:clickable="true"
                        android:focusable="true">

                        <ImageView
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:scaleType="fitCenter"
                            android:src="@drawable/tv_card_matches"
                            android:contentDescription="المباريات" />
                    </FrameLayout>

                    <!-- 5. beIN SPORTS -->
                    <FrameLayout
                        android:id="@+id/cardBeInSports"
                        android:layout_width="160dp"
                        android:layout_height="90dp"
                        android:layout_marginHorizontal="10dp"
                        android:background="@null"
                        android:clickable="true"
                        android:focusable="true">

                        <ImageView
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:scaleType="fitCenter"
                            android:src="@drawable/tv_card_bein"
                            android:contentDescription="بي إن سبورت" />
                    </FrameLayout>

                    <!-- 6. ACCOUNTS -->
                    <FrameLayout
                        android:id="@+id/cardAccounts"
                        android:layout_width="160dp"
                        android:layout_height="90dp"
                        android:layout_marginHorizontal="10dp"
                        android:background="@null"
                        android:clickable="true"
                        android:focusable="true">

                        <ImageView
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:scaleType="fitCenter"
                            android:src="@drawable/tv_card_accounts"
                            android:contentDescription="الحسابات" />
                    </FrameLayout>

                    <!-- 7. THEME (Wallpapers) -->
                    <FrameLayout
                        android:id="@+id/cardTheme"
                        android:layout_width="160dp"
                        android:layout_height="90dp"
                        android:layout_marginHorizontal="10dp"
                        android:background="@null"
                        android:clickable="true"
                        android:focusable="true">

                        <ImageView
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:scaleType="fitCenter"
                            android:src="@drawable/tv_card_theme"
                            android:contentDescription="خلفيات الشاشة" />
                    </FrameLayout>

                    <!-- 8. SETTINGS -->
                    <FrameLayout
                        android:id="@+id/cardSettings"
                        android:layout_width="160dp"
                        android:layout_height="90dp"
                        android:layout_marginHorizontal="10dp"
                        android:background="@null"
                        android:clickable="true"
                        android:focusable="true">

                        <ImageView
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:scaleType="fitCenter"
                            android:src="@drawable/tv_card_settings"
                            android:contentDescription="الإعدادات" />
                    </FrameLayout>
                </LinearLayout>
            </HorizontalScrollView>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:gravity="center"
                android:text="تصفح أفقي Google TV  •  تحديد احترافي بدون خلفيات شفافة"
                android:textColor="#7788AA"
                android:textSize="12sp" />

            <!-- User profiles Recycler hidden/moved to drawer or optional -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/usersRecyclerView"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:visibility="gone" />

            <LinearLayout
                android:id="@+id/loadingRow"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:visibility="gone" />
        </LinearLayout>
    </FrameLayout>

    <!-- ===== Navigation Drawer ===== -->
    <LinearLayout
        android:id="@+id/drawerMenu"
        android:layout_width="280dp"
        android:layout_height="match_parent"
        android:layout_gravity="end"
        android:background="#121228"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:gravity="center"
            android:text="LATCHI IPTV"
            android:textColor="#FFD700"
            android:textSize="22sp"
            android:textStyle="bold" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginVertical="16dp"
            android:background="#2d2d44" />

        <TextView
            android:id="@+id/drawerSupport"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginBottom="8dp"
            android:background="@drawable/bg_vip_grid_card"
            android:clickable="true"
            android:focusable="true"
            android:foreground="@drawable/focus_ring_vip"
            android:gravity="center_vertical"
            android:paddingHorizontal="16dp"
            android:text="📞 الدعم الفني (واتساب)"
            android:textColor="#39FF8B"
            android:textSize="15sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/drawerMatches"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginBottom="8dp"
            android:background="@drawable/bg_panel_premium_focusable"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center_vertical"
            android:paddingHorizontal="16dp"
            android:text="@string/drawer_matches"
            android:textColor="@android:color/white"
            android:textSize="16sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/drawerPrayer"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginBottom="8dp"
            android:background="@drawable/bg_panel_premium_focusable"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center_vertical"
            android:paddingHorizontal="16dp"
            android:text="@string/drawer_prayer"
            android:textColor="@android:color/white"
            android:textSize="16sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/drawerPricing"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginBottom="8dp"
            android:background="@drawable/bg_panel_premium_focusable"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center_vertical"
            android:paddingHorizontal="16dp"
            android:text="@string/drawer_pricing"
            android:textColor="@android:color/white"
            android:textSize="16sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/drawerThemeSettings"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginBottom="8dp"
            android:background="@drawable/bg_panel_premium_focusable"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center_vertical"
            android:paddingHorizontal="16dp"
            android:text="@string/theme_settings"
            android:textColor="@android:color/white"
            android:textSize="16sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/drawerSettings"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginBottom="8dp"
            android:background="@drawable/bg_panel_premium_focusable"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center_vertical"
            android:paddingHorizontal="16dp"
            android:text="@string/drawer_settings"
            android:textColor="@android:color/white"
            android:textSize="16sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/drawerAbout"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginBottom="8dp"
            android:background="@drawable/bg_panel_premium_focusable"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center_vertical"
            android:paddingHorizontal="16dp"
            android:text="@string/drawer_about"
            android:textColor="@android:color/white"
            android:textSize="16sp"
            android:textStyle="bold" />

        <View
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:gravity="center"
            android:text="LATCHI IPTV VIP"
            android:textColor="#666666"
            android:textSize="12sp" />
    </LinearLayout>

    <!-- 🚫 Completely Removed annoying DHIKR Fullscreen blocking overlay forever 🚫 -->
    <FrameLayout
        android:id="@+id/loadingOverlay"
        android:layout_width="1dp"
        android:layout_height="1dp"
        android:visibility="gone" />

    <FrameLayout
        android:id="@+id/voiceOverlay"
        android:layout_width="1dp"
        android:layout_height="1dp"
        android:visibility="gone" />
</androidx.drawerlayout.widget.DrawerLayout>
